@model IEnumerable<Courses.Web.Models.DocumentRequest>
@{
    ViewData["Title"] = "Dokumentförfrågningar";
}

<h1>Dokumentförfrågningar</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger" role="alert">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">@TempData["Success"]</div>
}

@if (!Model.Any())
{
    <p class="text-muted">Du har inga dokumentförfrågningar.</p>
}
else
{
    @foreach (var r in Model)
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="mb-1">@r.Message</p>
                        <small class="text-muted">Skickad @r.RequestedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                    </div>
                    @if (r.IsFulfilled)
                    {
                        <span class="badge bg-success">Uppfylld</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Väntar på dokument</span>
                    }
                </div>

                @if (r.IsFulfilled && r.FileName != null)
                {
                    <p class="mt-2 mb-0 text-muted">Uppladdad fil: <strong>@r.FileName</strong></p>
                }

                @if (!r.IsFulfilled)
                {
                    <form asp-action="Upload" asp-route-id="@r.Id" method="post"
                          enctype="multipart/form-data" class="mt-3">
                        @Html.AntiForgeryToken()
                        <div class="d-flex gap-2 align-items-center">
                            <label for="file-@r.Id" class="visually-hidden">Välj PDF-fil att ladda upp</label>
                            <input id="file-@r.Id" type="file" name="file" accept=".pdf" class="form-control form-control-sm" style="max-width:300px" />
                            <button type="submit" class="btn btn-sm btn-primary">Ladda upp PDF</button>
                        </div>
                    </form>
                }
            </div>
        </div>
    }
}
