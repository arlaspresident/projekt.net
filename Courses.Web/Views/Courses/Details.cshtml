@model Courses.Web.Models.Course

@{
    ViewData["Title"] = Model.Title;
    var isEnrolled = (bool)ViewBag.IsEnrolled;
}

<h1>@Model.Title</h1>
<p class="text-muted">@Model.CourseCode &bull; @Model.Credits hp &bull; @Model.Category?.Name</p>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p>@Model.Description</p>
}

<dl class="row">
    <dt class="col-sm-2">Lärare</dt>
    <dd class="col-sm-10">@(Model.Teacher?.Name ?? "Ej angiven")</dd>

    @if (!string.IsNullOrEmpty(Model.SyllabusUrl))
    {
        <dt class="col-sm-2">Kursplan</dt>
        <dd class="col-sm-10"><a href="@Model.SyllabusUrl" target="_blank">Öppna kursplan</a></dd>
    }
</dl>

<hr />

@if (!User.Identity!.IsAuthenticated)
{
    <p>
        <a asp-area="Identity" asp-page="/Account/Login">Logga in</a> för att anmäla dig till kursen.
    </p>
}
else if (User.IsInRole("Student"))
{
    if (isEnrolled)
    {
        <p class="text-success fw-bold">Du är anmäld till denna kurs.</p>
        <form asp-controller="Enrollments" asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="courseId" value="@Model.Id" />
            <button type="submit" class="btn btn-outline-danger">Avanmäl</button>
        </form>
    }
    else
    {
        <form asp-controller="Enrollments" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="courseId" value="@Model.Id" />
            <button type="submit" class="btn btn-primary">Anmäl</button>
        </form>
    }
}
else
{
    <p class="text-muted">Enbart studenter kan anmäla sig till kurser.</p>
}

<div class="mt-3">
    <a asp-controller="Courses" asp-action="Index">Tillbaka till kurslistan</a>
</div>
