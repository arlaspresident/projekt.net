@model List<Courses.Web.Models.Enrollment>

<h1>Mina kurser</h1>

@if (!Model.Any())
{
    <p>Du är inte anmäld till några kurser ännu.</p>
}
else
{
    <ul class="list-unstyled">
    @foreach (var e in Model)
    {
        <li class="mb-2 d-flex align-items-center gap-3">
            <span><strong>@e.Course?.CourseCode</strong> – @e.Course?.Title</span>
            @if (e.IsApproved)
            {
                <span class="badge bg-success">Godkänd</span>
            }
            else
            {
                <span class="badge bg-warning text-dark">Väntar på godkännande</span>
            }
            <a asp-controller="Courses" asp-action="Details" asp-route-id="@e.CourseId">Detaljer</a>
            <form asp-controller="Enrollments" asp-action="Delete" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="courseId" value="@e.CourseId" />
                <button type="submit" class="btn btn-sm btn-outline-danger">Avanmäl</button>
            </form>
        </li>
    }
    </ul>
}