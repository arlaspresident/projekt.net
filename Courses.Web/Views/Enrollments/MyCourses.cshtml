@model List<Courses.Web.Models.Course>

<h1>Mina kurser</h1>

@if (!Model.Any())
{
    <p>Du är inte anmäld till några kurser ännu.</p>
}
else
{
    <ul>
    @foreach (var c in Model)
    {
        <li>
            <strong>@c.CourseCode</strong> – @c.Title
            <a asp-controller="Courses" asp-action="Details" asp-route-id="@c.Id">Detaljer</a>

            <form asp-controller="Enrollments" asp-action="Delete" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="courseId" value="@c.Id" />
                <button type="submit">Avanmäl</button>
            </form>
        </li>
    }
    </ul>
}