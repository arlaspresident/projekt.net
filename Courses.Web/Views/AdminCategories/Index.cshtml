@model List<Courses.Web.Models.Category>

@{
    ViewData["Title"] = "Hantera kategorier";
}

<h1>Kategorier</h1>
<a asp-action="Create" class="btn btn-success mb-3">+ Ny kategori</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Namn</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Redigera</a>
                    <form asp-action="Delete" asp-route-id="@c.Id" method="post" style="display:inline;"
                          onsubmit="return confirm('Ta bort @c.Name?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">Ta bort</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-controller="Admin" asp-action="Index">← Tillbaka till adminpanel</a>
